---
import "../styles/global.css";
import { site } from "../data/site";
import navStyles from "../components/Nav.module.css";

const {
  title = site.name,
  description = site.title,
  currentPath = "/",
  image = "/og-image.png",
  type = "website",
} = Astro.props;

const navItems = [
  { label: "Home", href: "/" },
  { label: "CV", href: "/cv" },
];

const linkedIn = site.socialLinks.find((link) => link.label === "LinkedIn");
const currentYear = new Date().getFullYear();
const siteOrigin = Astro.site ?? new URL("https://vistan.me");
const canonicalURL = new URL(Astro.url.pathname, siteOrigin);
const socialImageURL = new URL(image, siteOrigin);
const socialImageType = image.endsWith(".png") ? "image/png" : "image/svg+xml";
const socialLinks = site.socialLinks.map((link) => link.href);
const structuredData = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: site.name,
    url: siteOrigin.href,
    description: site.title,
  },
  {
    "@context": "https://schema.org",
    "@type": "Person",
    name: site.name,
    jobTitle: site.role,
    description: site.intro,
    url: siteOrigin.href,
    email: `mailto:${site.email}`,
    address: {
      "@type": "PostalAddress",
      addressLocality: "Copenhagen",
      addressCountry: "DK",
    },
    sameAs: socialLinks,
  },
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    name: title,
    description,
    url: canonicalURL.href,
    isPartOf: {
      "@type": "WebSite",
      name: site.name,
      url: siteOrigin.href,
    },
    about: {
      "@type": "Person",
      name: site.name,
    },
  },
];

const themeScript = `
  (() => {
    const storageKey = "vistan-theme";
    const root = document.documentElement;
    const stored = localStorage.getItem(storageKey);
    const systemTheme = window.matchMedia("(prefers-color-scheme: dark)").matches
      ? "dark"
      : "light";
    const theme =
      stored === "dark" || stored === "light" ? stored : systemTheme;

    root.dataset.theme = theme;
    root.style.colorScheme = theme;
  })();
`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={socialImageURL} />
    <meta property="og:image:type" content={socialImageType} />
    <meta
      property="og:image:alt"
      content={`${site.name} — engineering manager and product engineering lead`}
    />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageURL} />
    <meta
      name="twitter:image:alt"
      content={`${site.name} — engineering manager and product engineering lead`}
    />
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(structuredData)}
    />
    <script is:inline set:html={themeScript} />
  </head>
  <body>
    <div
      class="mx-auto flex min-h-screen max-w-3xl flex-col px-4 pt-6 pb-14 sm:px-10 sm:pt-10 sm:pb-16"
    >
      <header class={navStyles.header}>
        <a class={navStyles.brand} href="/">{site.name}</a>
        <div class={navStyles.controls}>
          <nav aria-label="Primary">
            <ul class={navStyles.navList}>
              {
                navItems.map((item) => (
                  <li>
                    <a
                      class:list={[
                        navStyles.navLink,
                        currentPath === item.href && navStyles.navLinkActive,
                      ]}
                      href={item.href}
                    >
                      {item.label}
                    </a>
                  </li>
                ))
              }
              {linkedIn && (
                <li>
                  <a
                    class={navStyles.navLink}
                    href={linkedIn.href}
                    target="_blank"
                    rel="noreferrer"
                  >
                    LinkedIn
                  </a>
                </li>
              )}
              <li>
                <a class={navStyles.navLink} href={`mailto:${site.email}`}>
                  Email
                </a>
              </li>
            </ul>
          </nav>
          <button
            class={navStyles.themeButton}
            type="button"
            aria-label="Activate dark theme"
            data-theme-toggle
          >
            <span class={navStyles.themeMobile} aria-hidden="true">
              <span class:list={[navStyles.themeMobileIcon, navStyles.themeSun]}>
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.8"
                >
                  <circle cx="12" cy="12" r="4"></circle>
                  <path
                    d="M12 2.5v2.5M12 19v2.5M21.5 12H19M5 12H2.5M18.7 5.3l-1.8 1.8M6.1 17.9l-1.8 1.8M18.7 18.7l-1.8-1.8M6.1 6.1 4.3 4.3"
                  ></path>
                </svg>
              </span>
              <span class={navStyles.themeMobileText} data-theme-text>Dark</span>
            </span>
            <span class={navStyles.themeTrack} aria-hidden="true">
              <span class:list={[navStyles.themeIcon, navStyles.themeSun]}>
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.8"
                >
                  <circle cx="12" cy="12" r="4"></circle>
                  <path
                    d="M12 2.5v2.5M12 19v2.5M21.5 12H19M5 12H2.5M18.7 5.3l-1.8 1.8M6.1 17.9l-1.8 1.8M18.7 18.7l-1.8-1.8M6.1 6.1 4.3 4.3"
                  ></path>
                </svg>
              </span>
              <span class:list={[navStyles.themeIcon, navStyles.themeMoon]}>
                <svg viewBox="0 0 24 24" fill="currentColor">
                  <path
                    d="M20.2 15.4A8.5 8.5 0 0 1 8.6 3.8a.75.75 0 0 0-.92-.92A9.75 9.75 0 1 0 21.14 16.32a.75.75 0 0 0-.94-.92Z"
                  ></path>
                </svg>
              </span>
              <span class={navStyles.themeThumb}></span>
            </span>
            <span class={navStyles.srOnly} data-theme-label>Dark theme</span>
          </button>
        </div>
      </header>
      <main class="flex-1">
        <slot />
      </main>
      <footer class={navStyles.footer}>
        <p class={navStyles.footerText}>
          {site.name} · {site.location}
        </p>
        <p class={navStyles.footerText}>© {currentYear}</p>
      </footer>
    </div>
    <script is:inline>
      const storageKey = "vistan-theme";
      const root = document.documentElement;
      const toggle = document.querySelector("[data-theme-toggle]");
      const label = document.querySelector("[data-theme-label]");
      const themeText = document.querySelector("[data-theme-text]");
      const systemPreference = window.matchMedia(
        "(prefers-color-scheme: dark)",
      );

      const applyTheme = (theme) => {
        root.dataset.theme = theme;
        root.style.colorScheme = theme;
      };

      const syncLabel = (theme) => {
        if (!toggle) return;
        toggle.setAttribute(
          "aria-pressed",
          theme === "dark" ? "true" : "false",
        );
        toggle.setAttribute(
          "aria-label",
          theme === "dark" ? "Activate light theme" : "Activate dark theme",
        );
        if (label) {
          label.textContent = theme === "dark" ? "Light theme" : "Dark theme";
        }
        if (themeText) {
          themeText.textContent = theme === "dark" ? "Light" : "Dark";
        }
      };

      toggle?.addEventListener("click", () => {
        const nextTheme = root.dataset.theme === "dark" ? "light" : "dark";
        applyTheme(nextTheme);
        localStorage.setItem(storageKey, nextTheme);
        syncLabel(nextTheme);
      });

      systemPreference.addEventListener("change", (event) => {
        if (localStorage.getItem(storageKey)) return;
        const theme = event.matches ? "dark" : "light";
        applyTheme(theme);
        syncLabel(theme);
      });

      syncLabel(root.dataset.theme === "dark" ? "dark" : "light");
    </script>
  </body>
</html>

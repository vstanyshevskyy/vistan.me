---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../data/site";
import styles from "./_index.module.css";
---

<BaseLayout
  title={`${site.name} | Engineering Manager`}
  description={site.title}
  currentPath="/"
>
  <section class={styles.hero}>
    <p class={styles.greeting}>{site.role}</p>
    <h1 class={styles.title}>{site.title}</h1>
    <p class={styles.intro}>{site.intro}</p>
    <p class={styles.availability}>{site.availability}</p>
  </section>

  <section class={styles.section} aria-labelledby="summary-title">
    <h2 class={styles.sectionTitle} id="summary-title">Summary</h2>
    <div class={styles.stack}>
      {site.summary.map((item) => <p class={styles.entryExcerpt}>{item}</p>)}
    </div>
  </section>

  <section class={styles.section} aria-labelledby="highlights-title">
    <h2 class={styles.sectionTitle} id="highlights-title">Selected impact</h2>
    <ul class={styles.list}>
      {
        site.highlights.map((highlight) => (
          <li class={styles.listItem}>{highlight}</li>
        ))
      }
    </ul>
  </section>

  <section class={styles.section} aria-labelledby="articles-title">
    <h2 class={styles.sectionTitle} id="articles-title">Articles</h2>
    <div class={styles.stack}>
      {
        site.articles.map((article) => (
          <article class={styles.entry}>
            <h3 class={styles.entryTitle}>
              <a
                class={styles.entryLink}
                href={article.href}
                target="_blank"
                rel="noreferrer"
              >
                {article.title}
              </a>
            </h3>
            <p class={styles.entryExcerpt}>
              {article.date} · {article.excerpt}
            </p>
          </article>
        ))
      }
    </div>
  </section>

  <section class={styles.section} aria-labelledby="experience-title">
    <h2 class={styles.sectionTitle} id="experience-title">Recent experience</h2>
    <div class={styles.stack}>
      {
        site.experience.slice(0, 3).map((role) => (
          <article class={styles.entry}>
            <h3 class={styles.entryTitle}>
              {role.role} · {role.company}
            </h3>
            <p class={styles.entryExcerpt}>
              {role.period} · {role.meta}
            </p>
          </article>
        ))
      }
    </div>
  </section>

  <section class={styles.section} aria-labelledby="speaking-title">
    <h2 class={styles.sectionTitle} id="speaking-title">Public speaking</h2>
    <div class={styles.stack}>
      {
        site.talks.map((talk) => (
          <article class={styles.entry}>
            <h3 class={styles.entryTitle}>{talk.title}</h3>
            <p class={styles.entryExcerpt}>{talk.excerpt}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class={styles.section} aria-labelledby="certificates-title">
    <h2 class={styles.sectionTitle} id="certificates-title">Certificates</h2>
    <ul class={styles.list}>
      {
        site.certificates.map((certificate) => (
          <li class={styles.listItem}>
            <a
              class={styles.entryLink}
              href={certificate.href}
              target="_blank"
              rel="noreferrer"
            >
              {certificate.title}
            </a>
            <span class={styles.listMeta}> · {certificate.meta}</span>
          </li>
        ))
      }
    </ul>
  </section>

  <section class={styles.section} aria-labelledby="socials-title">
    <h2 class={styles.sectionTitle} id="socials-title">Elsewhere</h2>
    <div class={styles.socials}>
      {
        site.socialLinks.map((link) => (
          <a
            class={styles.socialLink}
            href={link.href}
            target="_blank"
            rel="noreferrer"
          >
            {link.label}
          </a>
        ))
      }
      <a class={styles.socialLink} href={`mailto:${site.email}`}> Email </a>
      <span class={styles.socialMeta}>{site.location}</span>
    </div>
  </section>

  <section class={styles.section} aria-labelledby="contact-title">
    <h2 class={styles.sectionTitle} id="contact-title">Contact</h2>
    <form
      class={styles.form}
      name="contact"
      method="POST"
      data-netlify="true"
      netlify-honeypot="bot-field"
    >
      <input type="hidden" name="form-name" value="contact" />
      <input type="hidden" name="bot-field" />
      <label class={styles.label}>
        Name
        <input
          class={styles.input}
          type="text"
          name="name"
          autocomplete="name"
          required
        />
      </label>
      <label class={styles.label}>
        Email
        <input
          class={styles.input}
          type="email"
          name="email"
          autocomplete="email"
          required
        />
      </label>
      <label class={styles.label}>
        Message
        <textarea
          class:list={[styles.input, styles.textarea]}
          name="message"
          required></textarea>
      </label>
      <button class={styles.button} type="submit">Send message</button>
    </form>
  </section>
</BaseLayout>
